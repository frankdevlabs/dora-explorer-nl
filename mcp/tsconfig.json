{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "..",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "../src/lib/types.ts",
    "../src/lib/instruments.ts",
    "../src/lib/search-core.ts",
    "../src/lib/search-expansion.ts"
  ]
}
